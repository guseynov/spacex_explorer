DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eonet_explorer?schema=public"

# Optional: use your own MapLibre-compatible style instead of the public demo style.
# Example providers: MapTiler, Stadia Maps, Mapbox-compatible self-hosted styles.
NEXT_PUBLIC_MAP_STYLE_URL=""

# Optional: override NASA EONET endpoint. The public EONET API does not require an API key.
EONET_API_BASE_URL="https://eonet.gsfc.nasa.gov/api/v3"
EONET_SYNC_RECENT_DAYS="30"
EONET_REQUEST_DELAY_MS="1000"
EONET_MAX_RETRIES="3"
EONET_BACKFILL_START="2018-01-01"

# Optional: protect manual calls to /api/cron/eonet-sync.
# Vercel Cron requests also include x-vercel-cron: 1.
EONET_SYNC_SECRET=""
